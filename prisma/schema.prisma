generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  name                 String?
  password             String?
  creditBalance        Int                   @default(1000)
  planType             String?               @default("FREE")
  onboardingCompleted  Boolean               @default(false)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  usageType            String?
  professionCategory   String?
  profileImage         String?

  conversations        Conversation[]
  subscriptions        Subscription[]
  creditTransactions   CreditTransaction[]
  payments             Payment[]

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

model Subscription {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status             String    @default("ACTIVE")
  plan               String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  // Provider references (optional uniques for idempotency per provider)
  stripeSubscriptionId       String?  @unique
  mercadoPagoPaymentId       String?  @unique
  payments           Payment[]

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([userId, status])
}

model CreditTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  type      String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Conversation {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String?
  modelUsed  String?
  isArchived Boolean   @default(false)
  messages   Message[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([userId, isArchived])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  modelUsed      String?
  tokensUsed     Int?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

model Payment {
  id                   String        @id @default(cuid())
  userId               String
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Optional relation to subscription when applicable
  subscriptionId       String?
  subscription         Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  amount               Float
  currency             String?
  status               String?
  provider             String?
  paymentMethod        String?
  // Provider external references / idempotency keys
  externalId           String?       @unique
  mercadoPagoPaymentId String?       @unique
  // Credits purchase linkage (optional – some flows use credit packages)
  creditPackageId      String?
  createdAt            DateTime      @default(now())

  @@index([userId, createdAt])
}

// Outbox/Log for MercadoPago webhooks (Transactional Outbox pattern)
model MercadoPagoWebhookLog {
  id        String   @id @default(cuid())
  body      String
  headers   String?
  status    String   // PENDING | PROCESSED | FAILED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Catalog for credit packages used in some payment flows
model CreditPackage {
  id        String   @id @default(cuid())
  name      String   @unique
  credits   Int
  price     Float
  currency  String
  planType  String?
  createdAt DateTime @default(now())
}
